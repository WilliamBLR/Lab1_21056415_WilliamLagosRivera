#lang racket

#lang racket

(require "21056415-2base.rkt")
(require "21056415-2TDA-Carta.rkt")
(require "21056415-2TDA-Criatura.rkt")

(provide make-jugador
         jugador?
         jugador-nombre
         jugador-mazo
         jugador-mano
         jugador-activo
         jugador-banca
         jugador-descarte
         jugador-premios
         set-jugador-mano
         set-jugador-activo
         set-jugador-banca)

#|




Debe guardar:
- su nombre
- su mazo
- las cartas que tiene en mano
- su criatura activa
- su banca
- cartas descartadas
- premios

Representacion:

(list 'jugador nombre mazo mano activo banca descarte premios)


|#

;;Constructor

;Nuevamente y al igual que en todo verificamos toooodooo
(define (make-jugador nombre mazo mano activo banca descarte premios)
  (if (and (symbol? nombre)
           (list? mazo)
           (list? mano)
           (or (criatura? activo) (equal? activo '()))
           (list? banca)
           (list? descarte)
           (list? premios))
      (list 'jugador nombre mazo mano activo banca descarte premios)
      #f))


;;Pertenencia

(define (jugador? j)
  (and (list? j)
       (= (length j) 8)
       (equal? (car j) 'jugador)
       (symbol? (cadr j))
       (list? (caddr j))
       (list? (list-ref j 3))
       (or (criatura? (list-ref j 4))
           (equal? (list-ref j 4) '()))
       (list? (list-ref j 5))
       (list? (list-ref j 6))
       (list? (list-ref j 7))))


;;Selectores

(define (jugador-nombre j)
  (if (jugador? j)
      (cadr j)
      #f))

(define (jugador-mazo j)
  (if (jugador? j)
      (caddr j)
      #f))

(define (jugador-mano j)
  (if (jugador? j)
      (list-ref j 3)
      #f))

(define (jugador-activo j)
  (if (jugador? j)
      (list-ref j 4)
      #f))

(define (jugador-banca j)
  (if (jugador? j)
      (list-ref j 5)
      #f))

(define (jugador-descarte j)
  (if (jugador? j)
      (list-ref j 6)
      #f))

(define (jugador-premios j)
  (if (jugador? j)
      (list-ref j 7)
      #f))


;;Modificadores

(define (set-jugador-mano j nueva-mano)
  (if (and (jugador? j)
           (list? nueva-mano))
      (make-jugador (jugador-nombre j)
                    (jugador-mazo j)
                    nueva-mano
                    (jugador-activo j)
                    (jugador-banca j)
                    (jugador-descarte j)
                    (jugador-premios j))
      #f))

(define (set-jugador-activo j nuevo-activo)
  (if (and (jugador? j)
           (or (criatura? nuevo-activo) (equal? nuevo-activo '())))
      (make-jugador (jugador-nombre j)
                    (jugador-mazo j)
                    (jugador-mano j)
                    nuevo-activo
                    (jugador-banca j)
                    (jugador-descarte j)
                    (jugador-premios j))
      #f))

(define (set-jugador-banca j nueva-banca)
  (if (and (jugador? j)
           (list? nueva-banca))
      (make-jugador (jugador-nombre j)
                    (jugador-mazo j)
                    (jugador-mano j)
                    (jugador-activo j)
                    nueva-banca
                    (jugador-descarte j)
                    (jugador-premios j))
      #f))
